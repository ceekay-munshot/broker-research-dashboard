{
  "name": "broker-research-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Broker Research OS — broker research email dashboard (frontend MVP)",
  "scripts": {
    "dev": "vite",
    "dev:local": "VITE_RESEARCH_ADAPTER=local VITE_API_BASE_URL=http://localhost:4000 VITE_API_TOKEN=dev-token vite",
    "dev:upstream": "VITE_RESEARCH_ADAPTER=upstream vite",
    "dev:upstream-fixture": "VITE_RESEARCH_ADAPTER=upstream-fixture vite",
    "dev:pages": "npx wrangler pages dev . -- npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json && tsc --noEmit -p functions/tsconfig.json",
    "test": "npm run test:resolver && npm run test:transform && npm run test:worklog && npm run test:bybroker && npm run test:colors && npm run test:parser && npm run test:vocab && npm run test:policy && npm run test:textCleaners && npm run test:brokerSender && npm run test:reportDetail && npm run test:disagreementInsight && tsx src/adapters/serverOutput/__tests__/noteInsight.ts && tsx src/adapters/serverOutput/__tests__/targetPrice.ts",
    "test:parser": "tsx src/lib/__tests__/stockPriceParser.ts",
    "test:vocab": "tsx src/lib/__tests__/signalVocab.ts",
    "test:policy": "tsx src/lib/__tests__/signalPolicy.ts",
    "test:textCleaners": "tsx src/lib/__tests__/researchTextCleaners.ts",
    "test:brokerSender": "tsx src/lib/__tests__/brokerSender.ts",
    "test:reportDetail": "tsx src/viewModels/__tests__/reportDetail.ts",
    "test:disagreementInsight": "tsx src/viewModels/__tests__/disagreementInsight.ts",
    "test:contract": "tsx src/adapters/upstream/__tests__/contract.ts",
    "test:colors": "tsx src/lib/__tests__/semanticColor.ts",
    "test:resolver": "tsx src/adapters/serverOutput/__tests__/brokerResolver.ts",
    "test:transform": "tsx src/adapters/serverOutput/__tests__/emailApiTransform.ts",
    "test:worklog": "tsx src/viewModels/worklog/__tests__/worklog.ts",
    "test:bybroker": "tsx src/viewModels/__tests__/byBroker.ts",
    "test:bridge":   "tsx src/adapters/rawUpstream/__tests__/bridge.ts",
    "test:pipeline": "tsx server/src/pipeline/__tests__/pipeline.ts",
    "test:sync":     "tsx server/src/sync/__tests__/sync.ts",
    "test:eval":     "tsx server/src/eval/__tests__/eval.ts",
    "test:corrections": "tsx server/src/corrections/__tests__/corrections.ts",
    "test:llm":      "tsx server/src/llm/__tests__/llm.ts",
    "ops":           "tsx server/src/cli/ops.ts",
    "upstream:compare": "tsx src/adapters/upstream/__tests__/compare.ts",
    "upstream:ready":   "tsx src/adapters/upstream/__tests__/readiness.ts",
    "server:dev": "tsx server/src/index.ts",
    "server:ingest": "tsx server/src/index.ts --ingest-only",
    "server:test": "tsx server/src/__tests__/ingestEml.ts",
    "test:tenant":   "tsx server/src/__tests__/tenantIsolation.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
