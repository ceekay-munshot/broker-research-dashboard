# ───────────────────────────────────────────────────────────────────────
# Broker Research Dashboard — runtime env
# Copy to .env.local and tune per environment. Vite picks up VITE_* only.
#
# The dashboard is a read-only analytics client. It does NOT ingest mail,
# authenticate users, or enforce tenant isolation — all three live in the
# external upstream API. See docs/architecture.md.
# ───────────────────────────────────────────────────────────────────────

# Which adapter backs the UI.
#
#   upstream   Production path. HttpResearchAdapter hits the external upstream
#              API. Scope (org, user) comes from the bearer token the host
#              injects via window.__BROKER_RESEARCH_DASHBOARD__ (see
#              docs/scope.md). This dashboard does not mint tokens.
#
#   local      Local dev harness. Same HTTP contract as `upstream`, but pointed
#              at the local server/ process which parses .eml fixtures from
#              server/fixtures/. Not a production path; handy for iterating on
#              the adapter, parsers, and UI without an upstream.
#
#   mock       Offline default. MockResearchAdapter serves src/mocks/* directly
#              and runs the deterministic engine on demand. No network.
#
#   mock-http  HttpResearchAdapter wired to a stub fetch backed by the mock
#              adapter. Exercises the full HTTP code path without a server —
#              the right mode for adapter-layer regression tests.
#
#   upstream-fixture
#              FixtureUpstreamAdapter. Serves the JSON fixtures in
#              src/adapters/upstream/fixtures/ through the translation
#              layer. Integration-rehearsal mode — use this to exercise the
#              wire-shape handshake offline before the real upstream ships.
VITE_RESEARCH_ADAPTER=mock

# Base URL the HTTP adapter prefixes to every request. Required when
# VITE_RESEARCH_ADAPTER=upstream or =local. No trailing slash.
#   VITE_API_BASE_URL=https://api.broker-research.example.com
VITE_API_BASE_URL=

# Dev-only bearer token fallback. Production deployments DO NOT set this —
# the host page injects tokens at runtime via
# `window.__BROKER_RESEARCH_DASHBOARD__.token`. Leaving this unset is fine
# for `mock` and `mock-http` modes.
VITE_API_TOKEN=
