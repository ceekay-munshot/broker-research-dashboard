# ───────────────────────────────────────────────────────────────────────
# Broker Research Dashboard — runtime env
# Copy to .env.local and tune per environment. Vite picks up VITE_* only.
# ───────────────────────────────────────────────────────────────────────

# Which adapter backs the UI.
#   mock       — in-process MockResearchAdapter (default, needs no backend)
#   http       — real HttpResearchAdapter against a live backend
#   http-stub  — HttpResearchAdapter wired to a stub fetch backed by mocks;
#                exercises the full HTTP code path without a real server.
VITE_RESEARCH_ADAPTER=mock

# Base URL the HTTP adapter prefixes to every request. Required when
# VITE_RESEARCH_ADAPTER=http. No trailing slash.
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Bearer token for the Authorization header. Leave unset to send no
# Authorization header (useful for the stub mode). Real deployments will
# replace this with a login-driven token store.
VITE_API_TOKEN=
