{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "dev-local",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:local"],
      "port": 5173
    },
    {
      "name": "dev-upstream",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:upstream"],
      "port": 5173
    },
    {
      "name": "fixture",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "VITE_PREVIEW_FIXTURE=1 npx vite --port 5174 --strictPort"],
      "port": 5174
    },
    {
      "name": "live-pages",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "npx wrangler pages dev ./dist --port 8788 --compatibility-date=2024-01-01"],
      "port": 8788
    }
  ]
}
